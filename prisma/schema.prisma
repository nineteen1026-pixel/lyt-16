generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Material {
  id        Int                   @id @default(autoincrement())
  name      String
  category  String
  unit      String
  createdAt DateTime              @default(now())
  requests  PurchaseRequestItem[]
  stock     Stock?
  entries   StockEntryItem[]
}

model Stock {
  id         Int      @id @default(autoincrement())
  materialId Int      @unique
  quantity   Float    @default(0)
  updatedAt  DateTime @updatedAt
  material   Material @relation(fields: [materialId], references: [id])
}

model PurchaseRequest {
  id        Int                   @id @default(autoincrement())
  title     String
  applicant String
  status    String                @default("pending")
  remark    String                @default("")
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  items     PurchaseRequestItem[]
}

model PurchaseRequestItem {
  id         Int             @id @default(autoincrement())
  requestId  Int
  materialId Int
  quantity   Float
  remark     String          @default("")
  material   Material        @relation(fields: [materialId], references: [id])
  request    PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model StockEntry {
  id        Int              @id @default(autoincrement())
  operator  String
  remark    String           @default("")
  createdAt DateTime         @default(now())
  items     StockEntryItem[]
}

model StockEntryItem {
  id         Int        @id @default(autoincrement())
  entryId    Int
  materialId Int
  quantity   Float
  remark     String     @default("")
  material   Material   @relation(fields: [materialId], references: [id])
  entry      StockEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model DharmaAssembly {
  id                   Int             @id @default(autoincrement())
  name                 String
  type                 String
  master               String
  startTime            DateTime
  endTime              DateTime
  hall                 String
  capacity             Int             @default(0)
  registrationDeadline DateTime?
  remark               String          @default("")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  registrations        Registration[]
}

model Registration {
  id         Int            @id @default(autoincrement())
  assemblyId Int
  name       String
  phone      String
  createdAt  DateTime       @default(now())
  assembly   DharmaAssembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)

  @@unique([assemblyId, phone])
}
